APP_NAME="Yndx Review"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=ru
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ru_RU

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
# Локально: localhost. На проде — пусто или test.ukidoshi.store (не localhost!)
SESSION_DOMAIN=localhost
# На проде с HTTPS: true. Для HTTP: false
SESSION_SECURE_COOKIE=

# Локально. На проде: test.ukidoshi.store (домен SPA без протокола)
SANCTUM_STATEFUL_DOMAINS=localhost:5173,127.0.0.1:5173,localhost:8000,127.0.0.1:8000

CACHE_STORE=file
QUEUE_CONNECTION=sync

VITE_APP_NAME="${APP_NAME}"
