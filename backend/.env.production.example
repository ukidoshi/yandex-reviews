# Скопируйте в backend/.env на сервере и подставьте APP_KEY (php artisan key:generate).

APP_NAME="Yndx Review"
APP_ENV=production
APP_KEY=base64:СГЕНЕРИРУЙТЕ_КЛЮЧ
APP_DEBUG=false
APP_URL=https://test.ukidoshi.store

APP_LOCALE=ru
APP_FALLBACK_LOCALE=en

DB_CONNECTION=sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=true

SANCTUM_STATEFUL_DOMAINS=test.ukidoshi.store

CACHE_STORE=file
QUEUE_CONNECTION=sync
